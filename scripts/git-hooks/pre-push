#!/bin/sh
# Optional local gate: npm run setup:git-hooks  (once per clone)
set -e
cd "$(git rev-parse --show-toplevel)"
# Skip local checks if harness-submit just verified this exact tree with the
# full candidate command. Otherwise run only the bounded static pre-push gate.
# Full tests/builds belong to CI; projects without CI must create the candidate
# receipt with `npm run check && node scripts/check-gate.mjs --write`.
if node scripts/check-gate.mjs 2>/dev/null; then
  exit 0
fi
echo "pre-push: running bounded npm run check:push ..."
npm run check:push
