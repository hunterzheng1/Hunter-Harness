#!/bin/sh
# Optional local gate: npm run setup:git-hooks  (once per clone)
set -e
cd "$(git rev-parse --show-toplevel)"
# Skip npm run check if harness-submit M5 just verified this exact index tree
# within 10 min (triple check in harness_check_gate.py: marker ts + command + tree).
# Any mismatch → fall through to the full check (safe default).
if python harness/scripts/harness_check_gate.py 2>/dev/null; then
  exit 0
fi
echo "pre-push: running npm run check ..."
npm run check
