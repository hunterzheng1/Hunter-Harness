{
  "name": "hunter-harness-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "scripts": {
    "build": "tsc -b && npm run bundle -w packages/cli && npm run copy-resources -w packages/cli && npm run bundle -w packages/skill-cli && npm run build -w apps/web",
    "typecheck": "tsc -b && npm run typecheck -w apps/web",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "smoke:pack": "node scripts/smoke-pack.mjs",
    "check": "npm run lint && npm run typecheck && npm test && npm run build && npm run smoke:pack"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "26.0.0",
    "eslint": "10.5.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vitest": "4.1.9"
  }
}
