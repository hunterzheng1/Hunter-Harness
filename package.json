{
  "name": "hunter-harness-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "scripts": {
    "build": "node node_modules/typescript/bin/tsc -b && npm run bundle -w packages/cli && npm run bundle -w packages/skill-cli && npm run build -w apps/web",
    "typecheck": "node node_modules/typescript/bin/tsc -b && npm run typecheck -w apps/web",
    "pretest": "npm run sync:harness",
    "test": "node node_modules/vitest/vitest.mjs run",
    "test:watch": "node node_modules/vitest/vitest.mjs",
    "lint": "node node_modules/eslint/bin/eslint.js .",
    "smoke:pack": "node scripts/smoke-pack.mjs",
    "sync:harness": "node scripts/sync-harness.mjs",
    "check": "npm run lint && npm run typecheck && npm test && npm run build",
    "check:all": "npm run check && npm run smoke:pack",
    "setup:git-hooks": "git config core.hooksPath scripts/git-hooks",
    "hh": "node ./packages/cli/dist/bin.js",
    "hunter-harness": "node ./packages/cli/dist/bin.js"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "26.0.0",
    "eslint": "10.5.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vitest": "4.1.9"
  }
}
