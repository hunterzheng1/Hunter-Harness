{
  "name": "@hunter-harness/skill-cli",
  "version": "0.1.2",
  "description": "Install and upload governed Hunter Harness skills",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "bin": {
    "hunter-harness-skill": "dist/bin.js"
  },
  "files": [
    "dist/bin.js"
  ],
  "scripts": {
    "build": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json && npm run bundle",
    "bundle": "node ../../scripts/bundle-cli.mjs",
    "typecheck": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "commander": "15.0.0",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  },
  "optionalDependencies": {
    "pacote": "21.4.0"
  },
  "devDependencies": {
    "@hunter-harness/contracts": "*",
    "@hunter-harness/core": "*",
    "@types/adm-zip": "^0.5.7",
    "@types/pacote": "^11.1.8",
    "esbuild": "^0.25.12"
  }
}
