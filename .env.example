# Non-secret Compose settings. Do not place real passwords or API tokens here.
POSTGRES_DB=hunter_harness
POSTGRES_USER=hunter_harness
POSTGRES_PASSWORD_FILE=./secrets/postgres_password.txt
BOOTSTRAP_TOKEN_FILE=./secrets/bootstrap_token.txt
HUNTER_HARNESS_NPM_SCOPE=@hunter-harness
NPM_TOKEN_FILE=./secrets/npm_token.txt
# Enable npm publishing with:
# docker compose -f docker-compose.yml -f docker-compose.npm.yml up
HUNTER_HARNESS_BOOTSTRAP_ACTOR=actor_owner
HUNTER_HARNESS_BOOTSTRAP_NAME=Owner
WEB_PORT=3000
